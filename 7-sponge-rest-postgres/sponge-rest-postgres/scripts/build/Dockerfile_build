# Need to package the code first `tar zcf sponge_rest_postgres.tar.gz $(ls)` and move it to the same directory as Dokerfile

# Compile the go code, you can specify the golang version
FROM golang:1.25-alpine as build
COPY . /go/src/sponge_rest_postgres
WORKDIR /go/src/sponge_rest_postgres
RUN tar zxf sponge_rest_postgres.tar.gz
RUN go env -w GOPROXY=https://goproxy.cn,direct
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /sponge_rest_postgres cmd/sponge_rest_postgres/main.go

# compressing binary files
#cd /
#upx -9 sponge_rest_postgres


# building images with binary
FROM alpine:latest
MAINTAINER zhufuyi "g.zhufuyi@gmail.com"

# add curl, used for http service checking, can be installed without it if deployed in k8s
RUN apk add curl

COPY --from=build /sponge_rest_postgres /app/sponge_rest_postgres
COPY --from=build /go/src/sponge_rest_postgres/configs/sponge_rest_postgres.yml /app/configs/sponge_rest_postgres.yml

# http port
EXPOSE 8080


WORKDIR /app

CMD ["./sponge_rest_postgres", "-c", "configs/sponge_rest_postgres.yml"]
# if you use the Configuration Center, sponge_rest_postgres.yml is changed to the Configuration Center configuration.
#CMD ["./sponge_rest_postgres", "-c", "configs/sponge_rest_postgres.yml", "-enable-cc"]
