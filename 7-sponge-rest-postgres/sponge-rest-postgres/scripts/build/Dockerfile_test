# Need to package the code first `tar zcf sponge_rest_postgres.tar.gz $(ls)` and move it to the same directory as Dokerfile
# rpc server source code, used to test rpc methods
FROM golang:1.25-alpine
MAINTAINER zhufuyi "g.zhufuyi@gmail.com"

# go test dependency packages
RUN apk add bash alpine-sdk build-base gcc

COPY . /go/src/sponge_rest_postgres
WORKDIR /go/src/sponge_rest_postgres
RUN tar zxf sponge_rest_postgres.tar.gz
RUN go env -w GOPROXY=https://goproxy.cn,direct
RUN go mod download
RUN rm -f sponge_rest_postgres.tar.gz

CMD ["sleep","86400"]
